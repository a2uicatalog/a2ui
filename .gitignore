# Symlink-safe: these paths are now symlinks into ../a2ui-private (durable
# home). git sees a symlink as a FILE, so the trailing-slash dir patterns
# above miss it — anchor without a slash so the symlink itself is ignored.
/ops
/thoughts
/apps-script-surface/gas-trade-bot
mcp/node_modules/
mcp/.env

# MCP server — deliberately NOT published (closed-source-for-launch decision 2026-07-04/05).
# Stripped from unpushed history via filter-repo 2026-07-05; lives on disk only.
mcp/

# ── key-shaped files: never track, regardless of location ────────────────────
# Google service-account keys, PEM/P12 material, OAuth client secrets.
**/SA/
*service*account*.json
*_sa.json
*-sa.json
*.pem
*.p12
client_secret*.json

# ── local-only backend + tooling (not part of the published catalogue) ───────
functions/
apps-script-surface/gas-mcp-demo-renderer/
spec/mcp-endpoint.md
spec/emit-deployment.md
scripts/build_demo_renderer.py
scripts/check_demo_renderer.py
scripts/smoke_demo_renderer.py
scripts/emit_deployment.py
scripts/check_mcp_tools.py
apps-script-surface/graduated-*/

# ── agent scratch: coding agents (Antigravity, etc.) drop conversation/debug logs
# into the working dir — never let those into the repo ───────────────────────
debug.md
**/debug.md
*.debug.md

# ── gated full-catalogue build (public-full/, deployed to full.a2uicatalog.ai
# via wrangler-full.toml) — contains rendered visibility:private atom content
# (article_journey, journey_step). MUST NOT reach the public GitHub repo —
# that would defeat the point of gating it behind Cloudflare Access. Local
# build artifact only, regenerated on demand via `ops.py run catalog-rebuild-full`.
public-full/

# atoms/schema.yaml temporarily gains the private-visibility blocks during
# catalog-rebuild-full (scripts/merge_private_schema.py splices them in from
# a2ui-private, then removes them again) — this is the safety net if a build
# is interrupted mid-merge, so the merged state can never get committed.
atoms/.schema.yaml.public-only.bak
