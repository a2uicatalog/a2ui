     {
      "id": "info-4",
      "atom": "key_value",
      "props": {
       "title": "Customization options",
       "items": [
        {
         "key": "gh config set",
         "description": "Adjust settings — e.g. gh config set editor \"code -w\" sets VS Code as your editor (the -w flag waits for the file to close)"
        },
        {
         "key": "gh alias set",
         "description": "Define shortcuts — e.g. gh alias set prd \"pr create --draft\" lets you run gh prd for a draft PR"
        },
        {
         "key": "extensions",
         "description": "Create or add custom commands via GitHub CLI extensions"
        }
       ]
      }
     },
