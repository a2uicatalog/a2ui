      "id": "cmd-7",
      "atom": "command_step",
      "props": {
       "label": "List pull requests awaiting your review",
       "command": "gh search prs --review-requested=@me --state=open"
      },
      "wire": {
       "done": "#s_7.value",
       "setDone": "#s_7.setValue"
      }
