       "text": "1 · Status & Repositories"
      }
     },
     {
      "id": "callout-3",
      "atom": "callout",
      "props": {
       "type": "warning",
       "text": "When you use some commands for the first time — for example gh codespace subcommands — you'll be prompted to add extra scopes to your authentication token. Follow the onscreen instructions."
      }
     },
     {
      "id": "cmd-1",
      "atom": "command_step",
      "props": {
       "label": "View your status across subscribed repositories",
       "command": "gh status",
       "hint": "Expect: Details of your current work on GitHub across all the repositories you're subscribed to"
      },
      "wire": {
       "done": "#s_1.value",
       "setDone": "#s_1.setValue"
      }
     },
     {
      "id": "cmd-2",
      "atom": "command_step",
      "props": {
       "label": "View a repository's description and README",
       "command": "gh repo view OWNER/REPO",
       "hint": "Add --web to open the repository in your default browser. Inside a local repo with a GitHub remote you can omit OWNER/REPO."
      },
      "wire": {
       "done": "#s_2.value",
       "setDone": "#s_2.setValue"
      }
     },
     {
      "id": "cmd-3",
      "atom": "command_step",
      "props": {
       "label": "Clone a repository",
       "command": "gh repo clone OWNER/REPO",
       "hint": "Expect: The repository is cloned to the directory from which you ran the command"
      },
      "wire": {
       "done": "#s_3.value",
       "setDone": "#s_3.setValue"
      }
     },
     {
      "id": "cmd-4",
      "atom": "command_step",
      "props": {
       "label": "Create a repository",
       "command": "gh repo create",
       "hint": "Follow the on-screen instructions. You can create a new empty repository and optionally clone it, or push an existing local repository and optionally set it as the remote."
      },
      "wire": {
       "done": "#s_4.value",
       "setDone": "#s_4.setValue"
      }
