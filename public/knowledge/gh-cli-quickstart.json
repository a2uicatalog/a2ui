         "key": "alias",
         "description": "A shortcut you define for a command you commonly run"
        },
        {
         "key": "extension",
         "description": "A custom command created or added to extend the GitHub CLI"
        },
        {
         "key": "cs",
         "description": "Shorthand you can substitute for codespace in any codespace command"
        }
       ]
      }
