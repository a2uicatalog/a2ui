     {
      "id": "cmd-1",
      "atom": "command_step",
      "props": {
       "label": "Scaffold a new project interactively",
       "command": "npm create vite@latest",
       "hint": "Follow the terminal prompts to select your framework and variant."
      },
      "wire": {
       "done": "#s_1.value",
       "setDone": "#s_1.setValue"
      }
     },
     {
      "id": "cmd-2",
      "atom": "command_step",
      "props": {
       "label": "Scaffold a project with explicit command line options",
       "command": "npm create vite@latest my-vue-app -- --template vue",
       "hint": "You can use . for the project name to scaffold in the current directory, or use the --no-interactive flag to skip interactive prompts."
      },
      "wire": {
       "done": "#s_2.value",
       "setDone": "#s_2.setValue"
      }
