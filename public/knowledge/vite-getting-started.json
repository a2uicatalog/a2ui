      "id": "prereq-1",
      "atom": "prerequisite_checklist",
      "props": {
       "title": "Prerequisites",
       "items": [
        "Node.js version 20.19+ or 22.12+ installed (some templates may require a higher version)"
       ]
      }
     },
     {
      "id": "concepts-2",
      "atom": "key_value",
      "props": {
       "title": "Concepts",
       "items": [
        {
         "key": "Vite",
         "description": "Build tool that aims to provide a faster and leaner development experience for modern web projects"
        },
        {
         "key": "Dev server",
         "description": "A server providing rich feature enhancements over native ES modules, such as fast Hot Module Replacement (HMR)"
        },
        {
         "key": "Build command",
         "description": "A command that bundles your code with Rolldown, pre-configured to output highly optimized static assets for production"
        },
        {
         "key": "Root directory",
         "description": "The concept of a directory which files are served from, where index.html acts as the front-and-central entry point"
        }
       ]
      }
     },
