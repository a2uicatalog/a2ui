      "wire": {
       "done": "#s_7.value",
       "setDone": "#s_7.setValue"
      }
     },
     {
      "id": "cmd-8",
      "atom": "command_step",
      "props": {
       "label": "Create the index.html entry point",
       "command": "Create an index.html file in your project root containing <p>Hello Vite!</p>.",
       "hint": "Vite treats index.html as source code and part of the module graph, automatically resolving script elements and rebasing URLs."
      },
      "wire": {
       "done": "#s_8.value",
       "setDone": "#s_8.setValue"
      }
     },
     {
      "id": "cmd-9",
      "atom": "command_step",
      "props": {
       "label": "Start the development server manually",
       "command": "npx vite",
