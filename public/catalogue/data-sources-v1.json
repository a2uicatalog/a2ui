{
  "catalogId": "a2ui-data-sources-v1",
  "version": 1,
  "csp": {
    "connect_domains": [
      "https://a2uicatalog.ai"
    ]
  },
  "proxy_base": "https://a2uicatalog.ai/api/data",
  "sources": {
    "adsb": {
      "description": "Live ADS-B traffic via adsb.lol (free, no auth). Feeds adsb_feed -> airspace_command_deck and friends.",
      "upstream": "https://api.adsb.lol/v2/lat/{lat}/lon/{lon}/dist/{dist}",
      "params": {
        "lat": {
          "type": "number",
          "default": 43.629
        },
        "lon": {
          "type": "number",
          "default": 1.363
        },
        "dist": {
          "type": "number",
          "default": 40,
          "max": 60
        }
      },
      "cache_ttl_s": 10,
      "min_client_refresh_s": 15,
      "limits": {
        "per_ip_per_min": 12,
        "upstream_per_min": 20
      },
      "project_fields": {
        "root": "ac",
        "fields": [
          "flight",
          "hex",
          "lat",
          "lon",
          "alt_baro",
          "gs",
          "track",
          "squawk"
        ]
      },
      "content_type": "application/json",
      "access": {
        "tier": "public",
        "scope": "data:adsb:read"
      },
      "consumers": [
        "adsb_feed"
      ]
    },
    "metar": {
      "description": "METAR weather via aviationweather.gov. Feeds metar_feed.",
      "upstream": "https://aviationweather.gov/api/data/metar?ids={station}&format=raw&hours=1",
      "params": {
        "station": {
          "type": "string",
          "pattern": "^[A-Z0-9]{4}$",
          "default": "LFBO"
        }
      },
      "cache_ttl_s": 300,
      "min_client_refresh_s": 60,
      "limits": {
        "per_ip_per_min": 6,
        "upstream_per_min": 6
      },
      "content_type": "text/plain",
      "access": {
        "tier": "public",
        "scope": "data:metar:read"
      },
      "consumers": [
        "metar_feed"
      ]
    }
  }
}
