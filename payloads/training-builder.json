{
 "type": "a2ui_wired_surface",
 "title": "Training App Builder",
 "state_primitives": [
  {
   "id": "md_input",
   "primitive": "ValueStore",
   "props": {
    "defaultValue": ""
   }
  }
 ],
 "actions": [
  {
   "id": "build",
   "type": "gas:build_training",
   "props": {
    "collect": {
     "md": "#md_input.value"
    }
   }
  }
 ],
 "layout": [
  {
   "id": "builder-heading",
   "atom": "subheading",
   "props": {
    "text": "Training App Builder"
   }
  },
  {
   "id": "builder-intro",
   "atom": "body",
   "props": {
    "text": "Paste a compliant training.md below (produced with the Gem prompt from any source document) and build it into a live training app. Parsing is fully deterministic — errors come back with lint codes you can paste straight back into Gemini."
   }
  },
  {
   "id": "md-textarea",
   "atom": "form_textarea",
   "props": {
    "label": "training.md source",
    "placeholder": "---\nid: my-training-app\ndomain: training\nname: \"…\"\nsource: \"…\"\nlicense: \"…\"\n---\n\n# Steps\n…",
    "rows": 16
   },
   "wire": {
    "onChange": "#md_input.setValue"
   }
  },
  {
   "id": "build-btn",
   "atom": "ripple_button",
   "props": {
    "label": "Build training app"
   },
   "wire": {
    "onClick": "#build.run"
   }
  },
  {
   "id": "build-error",
   "atom": "body",
   "props": {
    "text": ""
   },
   "wire": {
    "text": "#build.error"
   }
  },
  {
   "id": "build-result",
   "atom": "body",
   "props": {
    "text": ""
   },
   "wire": {
    "text": "#build.result"
   }
  },
  {
   "id": "builder-div",
   "atom": "divider"
  },
  {
   "id": "builder-hub-note",
   "atom": "body",
   "props": {
    "text": "All built apps are listed on the Training Hub: append ?nav=training-hub to this web app URL."
   }
  }
 ]
}
